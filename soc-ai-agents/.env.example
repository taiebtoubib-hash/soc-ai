ENV=development
ENV=development

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:29092
USE_KAFKA=false
# Wazuh
WAZUH_HOST=
WAZUH_PORT=55000
WAZUH_USER=
WAZUH_PASSWORD=

# Suricata
SURICATA_LOG_PATH=/var/log/suricata/eve.json

# Collector mode
COLLECTOR_MODE=simulate
WAZUH_POLL_INTERVAL=60

# Enrichment
ABUSEIPDB_KEY=

# Notifications
SLACK_WEBHOOK_URL=

# Shuffle SOAR
SHUFFLE_WEBHOOK_URL=
SHUFFLE_ENABLED=false

# Vector DB
CHROMA_HOST=localhost
CHROMA_PORT=8000

# False Positive threshold
FP_SCORE_THRESHOLD=0.60

# ML Model Paths (mounted via Docker at /app/ml_models)
ML_THREAT_MODEL_PATH=/app/ml_models/threat_model.pkl
ML_ATTACK_MODEL_PATH=/app/ml_models/attack_type_model.pkl
ML_PREPROCESSOR_PATH=/app/ml_models/preprocessor.pkl
ML_ENCODERS_PATH=/app/ml_models/encoders.pkl
ML_FP_MODEL_PATH=/app/ml_models/fp_model.pkl
ML_FP_CLASSIFIER_PATH=/app/ml_models/fp_classifier.pkl
ML_ANOMALY_MODEL_PATH=/app/ml_models/threat_model.pkl
# Detection thresholds
ML_THREAT_THRESHOLD=0.75
ML_SUSPECT_THRESHOLD=0.45
FP_SCORE_THRESHOLD=0.60

# Ollama LLM Integration
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=mistral:7b
LLM_ENABLED=false
LLM_TIMEOUT=30