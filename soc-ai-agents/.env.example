ENV=development

# Wazuh
WAZUH_HOST=
WAZUH_PORT=55000
WAZUH_USER=
WAZUH_PASSWORD=

# Suricata
SURICATA_LOG_PATH=/var/log/suricata/eve.json

# Collector mode
COLLECTOR_MODE=simulate
WAZUH_POLL_INTERVAL=60

# Enrichment
ABUSEIPDB_KEY=

# Notifications
SLACK_WEBHOOK_URL=

# Shuffle SOAR
SHUFFLE_WEBHOOK_URL=
SHUFFLE_ENABLED=false

# Vector DB
CHROMA_HOST=localhost
CHROMA_PORT=8000

# ML Model Paths
ML_THREAT_MODEL_PATH=../soc-ai-training/ml_models/production/threat_model.pkl
ML_ATTACK_MODEL_PATH=../soc-ai-training/ml_models/production/attack_type_model.pkl
ML_PREPROCESSOR_PATH=../soc-ai-training/ml_models/production/preprocessor.pkl
ML_ENCODERS_PATH=../soc-ai-training/ml_models/production/encoders.pkl
ML_FP_MODEL_PATH=../soc-ai-training/ml_models/production/fp_model.pkl
ML_FP_CLASSIFIER_PATH=../soc-ai-training/ml_models/production/fp_classifier.pkl

# Detection thresholds
ML_THREAT_THRESHOLD=0.75
ML_SUSPECT_THRESHOLD=0.45
FP_SCORE_THRESHOLD=0.60